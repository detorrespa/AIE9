# === RunPod Configuration ===
RUNPOD_SSH_HOST=<your-runpod-pod-ip>
RUNPOD_SSH_PORT=22
RUNPOD_SSH_USER=root
RUNPOD_SSH_KEY_PATH=~/.ssh/id_ed25519

# === Ollama Configuration ===
# When using SSH tunnel, this points to your local forwarded port
OLLAMA_BASE_URL=http://localhost:11435
OLLAMA_LLM_MODEL=gemma3:27b
OLLAMA_EMBED_MODEL=nomic-embed-text

# === Qdrant Configuration ===
# Local Qdrant (in-memory for dev, server for prod)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=aria_documents

# === Search Configuration ===
# DuckDuckGo search (no API key needed)
SEARCH_MAX_RESULTS=5

# === Document Paths ===
DOCUMENTS_DIR=./documents
